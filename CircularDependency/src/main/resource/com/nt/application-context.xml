<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:schemaLocation="http://www.springframework.org/schema/beans
http://www.springframework.org/schema/beans/spring-beans.xsd">
<bean id="a" class="com.nt.A"> <constructor-arg ref="b"/>
</bean>
<bean id="b" class="com.mt.B"> <constructor-arg ref="c"/>
</bean>
<bean id="c" class="com.nt.C"> <constructor-arg ref="a"/>
<bean id="student" class="com.nt.Student"/>
<bean id="course" class="com.nt.Student"/>

<!-- Notice: no property tag connects student to course -->
</bean>
